# Used by docker-compose.yml to run the whole platform (all 5 services + 7 workers +
# Postgres + Redis) as one stack. Copy to .env and fill in before `docker compose up`.
#
# Per-service dev without Docker still works with no setup (apps/api/.env.example covers
# that path) — this file is specifically for the containerized/production-shaped stack.

# --- Postgres (container-internal only; change if exposing the DB beyond this stack) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=adgo

# --- Required secrets — docker compose refuses to start without these set (no fallback) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# Shared secret the api gateway attaches to requests it proxies to auth-service/
# campaign-service/scraper-service, so those services can reject traffic that didn't come
# through the gateway.
INTERNAL_SERVICE_KEY=
# 32-byte hex key used to encrypt OAuth tokens at rest.
TOKEN_ENCRYPTION_KEY=

# --- Optional integrations (each degrades to a clearly-labeled mock/fallback if unset) ---
# Error tracking — falls back to console-only logging if unset.
SENTRY_DSN=
OPENAI_API_KEY=
RUNWAY_API_KEY=
SCRAPEGRAPH_SERVICE_URL=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
CRM_INTERNAL_SERVICE_KEY=
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
WOOCOMMERCE_STORE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
# Firecrawl (research crawler suite) — free-tier key at firecrawl.dev, no card required.
FIRECRAWL_API_KEY=
FIRECRAWL_MONTHLY_CREDIT_LIMIT=950
META_AD_LIBRARY_ACCESS_TOKEN=

# --- Public origin (used to build OAuth redirect URIs) ---
PUBLIC_ORIGIN=http://localhost:8080
