{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": [
    "src/**/*",
    "../api/src/modules/orchestrator/**/*",
    "../api/src/modules/pipeline/**/*",
    "../api/src/modules/optimization/**/*",
    "../api/src/modules/billing/**/*",
    "../api/src/modules/strategy/**/*",
    "../api/src/modules/business/**/*",
    "../api/src/modules/adapters/**/*",
    "../api/src/modules/logger/**/*",
    "../api/src/infra/**/*",
    "../api/src/db/**/*",
    "../api/src/types/**/*"
  ]
}
