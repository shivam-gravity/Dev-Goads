# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=dev-secret-change-me

# Strategy engine (optional — falls back to a deterministic mock strategy if unset)
ANTHROPIC_API_KEY=

# Meta ads adapter (optional — falls back to mock data if unset)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google ads adapter (optional — falls back to mock data if unset)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_ACCESS_TOKEN=
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adgo?schema=public"
