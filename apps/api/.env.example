# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=dev-secret-change-me

# Error tracking (optional — falls back to console-only logging if unset). Shared across
# all 5 services + all 7 background workers (see infra/errorTracking.ts). Get a DSN from
# sentry.io (or any Sentry-compatible self-hosted instance) for a new project.
SENTRY_DSN=

# Auth-service / campaign-service ports (see apps/auth-service, apps/campaign-service)
AUTH_SERVICE_PORT=4001
CAMPAIGN_SERVICE_PORT=4002
SCRAPER_SERVICE_PORT=4003
AUTH_SERVICE_URL=http://localhost:4001
CAMPAIGN_SERVICE_URL=http://localhost:4002
SCRAPER_SERVICE_URL=http://localhost:4003

# Shared secret the gateway attaches to requests it proxies to auth-service/campaign-service,
# so those services can reject traffic that didn't come through the gateway. Change this
# for any environment where the two services aren't behind a private network.
INTERNAL_SERVICE_KEY=dev-internal-key-change-me

# New Campaign research pipeline (marketResearch.ts): when OPENROUTER_API_KEY (below) is unset,
# this is used instead of the static hardcoded fallback text. Points at a local FastAPI service
# (apps/scraper-service/python/research_server.py) wrapping scrapegraphai + a local Ollama
# model — real, page-grounded extraction with no external API key required, but slower
# (~1-3min per URL on CPU) and lower-quality on inferential fields (audience/competitor/market
# reasoning) than the Groq path. Falls back to the static fallback text if unreachable.
SCRAPEGRAPH_SERVICE_URL="http://localhost:5055"

# Meta ads adapter (optional — falls back to mock data if unset)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google ads adapter (optional — falls back to mock data if unset)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_ACCESS_TOKEN=

# Google OAuth (optional — falls back to mock connect if unset). Create an OAuth 2.0
# Client ID (Web application) at console.cloud.google.com, and apply for/obtain a
# Google Ads developer token (GOOGLE_ADS_DEVELOPER_TOKEN above) — both are required
# for the real per-workspace connect flow, not just the legacy global-token adapter mode.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/google/oauth/callback

# TikTok ads adapter (optional — falls back to mock data if unset)
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# TikTok OAuth (optional — falls back to mock connect if unset). Register an app in the
# TikTok for Business developer portal (business-api.tiktok.com/portal) to get an app ID
# and secret — note this connects the per-workspace advertiser account for account
# selection/visibility; the live ad launch above still uses TIKTOK_ACCESS_TOKEN/
# TIKTOK_ADVERTISER_ID until TikTok gets the same per-workspace hierarchy depth Meta/Google have.
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/tiktok/oauth/callback

# Meta OAuth (optional — falls back to mock connect if unset). Register a Meta App
# at developers.facebook.com, add "Facebook Login for Business", and set the
# redirect URI below as an allowed OAuth redirect URI on that app.
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/meta/oauth/callback

# Meta Lead Ads webhook (optional — required only to receive real-time leadgen events).
# Set this to any random string and enter the same value as the "Verify Token" when
# subscribing your Meta App's webhook to the `leadgen` field at developers.facebook.com.
META_WEBHOOK_VERIFY_TOKEN=

# Shared secret sales_tech_backend (the CRM's Django backend) attaches to server-to-server
# calls at /api/crm/*, so this service can tell CRM traffic apart from the public internet.
# Deliberately separate from INTERNAL_SERVICE_KEY above — this one crosses a repo/company
# boundary and shouldn't share rotation blast-radius with the intra-monorepo services.
CRM_INTERNAL_SERVICE_KEY=

# Powers every AI feature: strategy generation, market research, insights, the strategist
# chat, and creative copy generation (optional — each falls back to a deterministic
# mock/static result if unset). OpenAI and Anthropic/Claude have been removed from this
# platform entirely — OpenRouter (below) is now the default/reliable LLM backend: an
# OpenAI-compatible aggregator fronting many upstream models (free-tier Llama/Qwen/DeepSeek
# plus paid GPT/Claude/Gemini) behind ONE key, which removed the single-provider daily-quota
# bottleneck Groq had. Get a key at openrouter.ai/keys. OPENROUTER_MODEL picks the model —
# default is a free tier; set a paid model (e.g. openai/gpt-4o-mini) for higher quality.
# Deep-research tasks run "dual" (OpenRouter + Mistral concurrently, best answer wins) — see
# infra/llmTaskConfig.ts. Image generation (modules/generation/imageProvider.ts) is OPT-IN:
# an in-process mock by default, a real chain only when IMAGE_GENERATION_ENABLED=true or a
# dedicated image key (OPENAI_API_KEY/STABILITY_API_KEY) is set.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-20b:free
# Optional — shown on OpenRouter's dashboard for attribution/ranking; harmless if unset.
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# Hard ceiling on COMBINED token usage across all LLM providers (OpenRouter, Ollama, Gemini,
# Mistral) together, enforced by infra/llmUsageBoundary.ts — a backstop against runaway
# usage (a retry storm, an unexpectedly large batch), not a cost lever (Groq/Ollama/Gemini/
# Mistral's free tiers already bound cost). Unlike a per-provider budget, this is a hard
# stop with NO fallback: once hit, llmRouter.ts refuses to attempt ANY provider for the
# rest of the UTC month, including the usual fallback-to-Groq safety net.
LLM_MONTHLY_TOKEN_BUDGET=5000000
# Campaign-generation research cache TTL. A completed research run for the same
# (workspace, business, url) is reused for this long before fresh research runs, so a repeat
# "generate" for the same business doesn't re-pay the 27 providers / ~50 searches / ~47 LLM
# calls. Default 604800000 (7 days). Keep <= the 14-day UI staleness horizon. Bypass
# per-request with { "forceRefresh": true } in the POST /campaigns/generate body.
CAMPAIGN_RESEARCH_CACHE_TTL_MS=604800000
# Cache quality-gate: a cached research run is only REUSED if its grounding
# (context.metadata.overallConfidence, 0-1) is >= this AND its company-identity anchor
# (context.company) is present. A degraded run (e.g. providers timed out under a Groq storm,
# leaving company=null and a confabulated market) is treated as a cache miss and re-researched
# instead of re-served. Default 0.50; a non-finite/out-of-[0,1] value falls back to 0.50. The
# company-null check is a hard invariant and is NOT affected by this number.
CAMPAIGN_RESEARCH_MIN_CONFIDENCE=0.5
RUNWAY_API_KEY=

# 32-byte hex key used to encrypt OAuth tokens at rest (Integration.data blob).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Shopify product catalog — global single-store fallback (optional — falls back to mock
# catalog data if unset, and is only used when a workspace hasn't installed the app below)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Shopify app install (optional — real per-merchant OAuth; required for App Store listing).
# Create an app at partners.shopify.com, set the redirect/webhook URLs below in its
# configuration, and enable the mandatory GDPR webhooks (app/uninstalled, customers/data_request,
# customers/redact, shop/redact) pointing at /api/webhooks/shopify/*.
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=
SHOPIFY_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/shopify/oauth/callback

# WooCommerce product catalog (optional — falls back to mock catalog data if unset)
WOOCOMMERCE_STORE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Firecrawl (optional — every Firecrawl-backed research provider degrades to a labeled partial
# result if unset). Get a free-tier API key (1,000 credits/mo, no card required) at
# Search (optional — degrades to a labeled partial result if unset). SearXNG is now the ONLY
# web-search backend (infra/searchRouter.ts, infra/searchTaskConfig.ts) — the metered paid
# vendors Tavily and Serper were removed. Powers SearchRankingProvider, ReviewsProvider/
# SocialMediaProvider's grounded fallback, and the generic runWebSearch. Self-hosted
# metasearch — see docker-compose.yml's `searxng` service + searxng/settings.yml. Point this
# at wherever that container is reachable. No per-call quota. Note: SearXNG applies its own
# relevance ranking, so SearchRankingProvider's `position` field is approximate (not exact
# Google rank order, which the removed Serper provided).
SEARXNG_BASE_URL=http://localhost:8888

# Crawl / content extraction (optional — degrades to in-house-only if unset). crawl4ai is now
# the ONLY external crawl backend (Firecrawl, the metered vendor, was removed). It runs
# CONCURRENTLY with the in-house Playwright scraper (scraper-service) and their results are
# merged — see infra/scrapeFallback.ts + infra/crawl4aiClient.ts. Self-hosted, no per-call
# quota — see docker-compose.yml's `crawl4ai` service. Point this at wherever that container
# is reachable.
CRAWL4AI_BASE_URL=http://localhost:11235
# Optional bearer token — set only if you started crawl4ai with auth required. Leave empty on
# a private network.
CRAWL4AI_API_TOKEN=

# Meta Ad Library API (optional — AdLibraryProvider skips the Meta source if unset; Google
# Ads Transparency Center coverage via the crawl layer still runs). Register a Meta developer
# app at developers.facebook.com and generate an access token with ads_read/public access to
# the ads_archive endpoint.
META_AD_LIBRARY_ACCESS_TOKEN=

# Per-task LLM assignment (infra/llmTaskConfig.ts, infra/llmRouter.ts) — lets specific
# agents/research providers/decision-engine steps run on a different model than the
# Groq default, via LLM_TASK_<TASK_NAME>="provider:model" overrides (see
# llmTaskConfig.ts's doc comment). Ollama/Gemini/Mistral below are each optional; an
# unconfigured one just means any task assigned to it falls straight through to Groq (see
# llmRouter.ts's fallback wrapping) rather than erroring.
#
# Ollama (local, free, no key needed) — install from ollama.com, `ollama pull <model>`.
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL=llama3.2
OLLAMA_MAX_CONCURRENT=2
#
# Gemini (Google) — aistudio.google.com -> Get API Key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
#
# Mistral — console.mistral.ai -> API Keys. Also the only remaining embeddings provider
# (mistral-embed) — see infra/mistralClient.ts and research/memory/MemoryCoordinator.ts.
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
#
# Kill switch: set to "false" to disable the auto-fallback-to-Groq behavior above and
# have an assigned non-Groq task fail outright instead (see llmRouter.ts).
LLM_TASK_FALLBACK_ENABLED=true

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adgo?schema=public"

# Redis (docker-compose service; not yet wired into the app — reserved for Phase 1 caching/job queue)
REDIS_URL="redis://localhost:6379"
