# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=dev-secret-change-me

# Error tracking (optional — falls back to console-only logging if unset). Shared across
# all 5 services + all 7 background workers (see infra/errorTracking.ts). Get a DSN from
# sentry.io (or any Sentry-compatible self-hosted instance) for a new project.
SENTRY_DSN=

# Auth-service / campaign-service ports (see apps/auth-service, apps/campaign-service)
AUTH_SERVICE_PORT=4001
CAMPAIGN_SERVICE_PORT=4002
SCRAPER_SERVICE_PORT=4003
AUTH_SERVICE_URL=http://localhost:4001
CAMPAIGN_SERVICE_URL=http://localhost:4002
SCRAPER_SERVICE_URL=http://localhost:4003

# Shared secret the gateway attaches to requests it proxies to auth-service/campaign-service,
# so those services can reject traffic that didn't come through the gateway. Change this
# for any environment where the two services aren't behind a private network.
INTERNAL_SERVICE_KEY=dev-internal-key-change-me

# New Campaign research pipeline (marketResearch.ts): when OPENAI_API_KEY (below) is unset,
# this is used instead of the static hardcoded fallback text. Points at a local FastAPI service
# (apps/scraper-service/python/research_server.py) wrapping scrapegraphai + a local Ollama
# model — real, page-grounded extraction with no external API key required, but slower
# (~1-3min per URL on CPU) and lower-quality on inferential fields (audience/competitor/market
# reasoning) than the OpenAI path. Falls back to the static fallback text if unreachable.
SCRAPEGRAPH_SERVICE_URL="http://localhost:5055"

# Meta ads adapter (optional — falls back to mock data if unset)
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google ads adapter (optional — falls back to mock data if unset)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_ACCESS_TOKEN=

# Google OAuth (optional — falls back to mock connect if unset). Create an OAuth 2.0
# Client ID (Web application) at console.cloud.google.com, and apply for/obtain a
# Google Ads developer token (GOOGLE_ADS_DEVELOPER_TOKEN above) — both are required
# for the real per-workspace connect flow, not just the legacy global-token adapter mode.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/google/oauth/callback

# TikTok ads adapter (optional — falls back to mock data if unset)
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# TikTok OAuth (optional — falls back to mock connect if unset). Register an app in the
# TikTok for Business developer portal (business-api.tiktok.com/portal) to get an app ID
# and secret — note this connects the per-workspace advertiser account for account
# selection/visibility; the live ad launch above still uses TIKTOK_ACCESS_TOKEN/
# TIKTOK_ADVERTISER_ID until TikTok gets the same per-workspace hierarchy depth Meta/Google have.
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/tiktok/oauth/callback

# Meta OAuth (optional — falls back to mock connect if unset). Register a Meta App
# at developers.facebook.com, add "Facebook Login for Business", and set the
# redirect URI below as an allowed OAuth redirect URI on that app.
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/meta/oauth/callback

# Meta Lead Ads webhook (optional — required only to receive real-time leadgen events).
# Set this to any random string and enter the same value as the "Verify Token" when
# subscribing your Meta App's webhook to the `leadgen` field at developers.facebook.com.
META_WEBHOOK_VERIFY_TOKEN=

# Shared secret sales_tech_backend (the CRM's Django backend) attaches to server-to-server
# calls at /api/crm/*, so this service can tell CRM traffic apart from the public internet.
# Deliberately separate from INTERNAL_SERVICE_KEY above — this one crosses a repo/company
# boundary and shouldn't share rotation blast-radius with the intra-monorepo services.
CRM_INTERNAL_SERVICE_KEY=

# Powers every AI feature: strategy generation, market research, insights, the strategist
# chat, and creative copy/image generation (optional — each of those falls back to a
# deterministic mock/static result if unset; image generation errors without it).
OPENAI_API_KEY=

# Hard monthly cap on THIS app's own OpenAI spend, enforced by infra/openaiBudget.ts (and
# mirrored in apps/scraper-service, which shares the same ledger file) — once tracked spend
# for the current UTC month reaches this, every OpenAI call degrades exactly like
# OPENAI_API_KEY being unset (llmRouter falls back to the assigned Ollama/Gemini task, image
# generation falls back to MockImageProvider, etc.). Set this to a fraction of your OpenAI
# account's real monthly budget if the same key is shared with other, unrelated projects —
# this ledger has no visibility into spend those other projects make outside this app.
# Default ($1) assumes a $10/month shared account and reserves 10% of it for this app.
OPENAI_MONTHLY_BUDGET_USD=1
RUNWAY_API_KEY=

# 32-byte hex key used to encrypt OAuth tokens at rest (Integration.data blob).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Shopify product catalog — global single-store fallback (optional — falls back to mock
# catalog data if unset, and is only used when a workspace hasn't installed the app below)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Shopify app install (optional — real per-merchant OAuth; required for App Store listing).
# Create an app at partners.shopify.com, set the redirect/webhook URLs below in its
# configuration, and enable the mandatory GDPR webhooks (app/uninstalled, customers/data_request,
# customers/redact, shop/redact) pointing at /api/webhooks/shopify/*.
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=
SHOPIFY_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/shopify/oauth/callback

# WooCommerce product catalog (optional — falls back to mock catalog data if unset)
WOOCOMMERCE_STORE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Firecrawl (optional — every Firecrawl-backed research provider degrades to a labeled partial
# result if unset). Get a free-tier API key (1,000 credits/mo, no card required) at
# firecrawl.dev -> dashboard -> API Keys. Powers WebsiteProvider, ProductProvider,
# NavigationProvider, SearchRankingProvider, AdLibraryProvider (Google side), GoogleSerpFeaturesProvider,
# RedditProvider, and the upgraded ReviewsProvider/SocialMediaProvider.
FIRECRAWL_API_KEY=
# Safety ceiling (in Firecrawl credits/calendar month) enforced by infra/firecrawlClient.ts's
# Redis-backed counter — deliberately below the free tier's real 1,000/mo cap so you never get
# surprised by an overage. Raise this if you upgrade to a paid Firecrawl plan.
FIRECRAWL_MONTHLY_CREDIT_LIMIT=950

# Meta Ad Library API (optional — AdLibraryProvider skips the Meta source if unset, Google
# Ads Transparency Center coverage via Firecrawl still runs). Register a Meta developer app
# at developers.facebook.com and generate an access token with ads_read/public access to the
# ads_archive endpoint.
META_AD_LIBRARY_ACCESS_TOKEN=

# Per-task LLM assignment (infra/llmTaskConfig.ts, infra/llmRouter.ts) — lets specific
# agents/research providers/decision-engine steps run on a different model than the
# OpenAI default, via LLM_TASK_<TASK_NAME>="provider:model" overrides (see
# llmTaskConfig.ts's doc comment). Every provider below is optional; an unconfigured one
# just means any task assigned to it falls straight through to OpenAI (see
# llmRouter.ts's fallback wrapping) rather than erroring.
#
# Ollama (local, free, no key needed) — install from ollama.com, `ollama pull <model>`.
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL=llama3.2
OLLAMA_MAX_CONCURRENT=2
#
# Claude (Anthropic) — console.anthropic.com -> API Keys.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
#
# Gemini (Google) — aistudio.google.com -> Get API Key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
#
# Kill switch: set to "false" to disable the auto-fallback-to-OpenAI behavior above and
# have an assigned non-OpenAI task fail outright instead (see llmRouter.ts).
LLM_TASK_FALLBACK_ENABLED=true

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adgo?schema=public"

# Redis (docker-compose service; not yet wired into the app — reserved for Phase 1 caching/job queue)
REDIS_URL="redis://localhost:6379"
