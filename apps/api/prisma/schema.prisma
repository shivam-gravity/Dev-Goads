// Data model for AdGo, mirroring the shape of the app that was actually built
// (see apps/api/src/db/db.ts for the SQLite predecessor this replaces).
// Most tables keep a `data Json` blob column matching how the app already
// reads/writes these records — this is a driver swap (SQLite -> Postgres),
// not a data-model redesign. workspace_members relates to Workspace (for the
// listWorkspacesForUser join) but NOT to User: inviteMember() can create a
// member row for an email with no User yet (userId = "pending:<email>"), so
// userId is a plain indexed column rather than an enforced FK.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String?
  name         String
  avatar       String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())

  @@map("users")
}

model Workspace {
  id        String            @id
  name      String
  ownerId   String
  plan      String            @default("starter")
  logoUrl   String?
  timezone  String?           @default("UTC")
  createdAt DateTime          @default(now())
  members   WorkspaceMember[]

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  role        String    @default("member")
  invitedAt   DateTime
  joinedAt    DateTime?

  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model Business {
  id          String   @id
  workspaceId String?
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("businesses")
}

model Strategy {
  id         String   @id
  businessId String
  data       Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@map("strategies")
}

model Campaign {
  id          String   @id
  businessId  String
  workspaceId String?
  data        Json
  updatedAt   DateTime @default(now())

  @@index([businessId])
  @@index([workspaceId])
  @@map("campaigns")
}

model AdSet {
  id          String   @id
  campaignId  String
  workspaceId String?
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([campaignId])
  @@index([workspaceId])
  @@map("ad_sets")
}

model Ad {
  id          String   @id
  adSetId     String
  workspaceId String?
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([adSetId])
  @@index([workspaceId])
  @@map("ads")
}

model Metric {
  id         String @id
  campaignId String
  data       Json
  date       String

  @@index([campaignId])
  @@map("metrics")
}

model Invoice {
  id         String   @id
  businessId String
  data       Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@map("invoices")
}

model Creative {
  id         String   @id
  businessId String?
  workspaceId String?
  data       Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([workspaceId])
  @@map("creatives")
}

model Asset {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("assets")
}

model Draft {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("drafts")
}

model Insight {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("insights")
}

model Integration {
  id          String   @id
  workspaceId String
  platform    String
  data        Json
  updatedAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([workspaceId, platform])
  @@map("integrations")
}

model Notification {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("notifications")
}

model SavedAudience {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("saved_audiences")
}
