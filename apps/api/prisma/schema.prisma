// Data model for AdGo, mirroring the shape of the app that was actually built
// (see apps/api/src/db/db.ts for the SQLite predecessor this replaces).
// Most tables keep a `data Json` blob column matching how the app already
// reads/writes these records — this is a driver swap (SQLite -> Postgres),
// not a data-model redesign. workspace_members relates to Workspace (for the
// listWorkspacesForUser join) but NOT to User: inviteMember() can create a
// member row for an email with no User yet (userId = "pending:<email>"), so
// userId is a plain indexed column rather than an enforced FK.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String?
  name         String
  avatar       String?
  googleId     String?  @unique
  isExternal   Boolean  @default(false)
  crmUserId    String?  @unique
  crmBusinessId String?
  crmPartnerId  String?
  createdAt    DateTime @default(now())

  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id         String    @id
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  family     String
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

model Workspace {
  id        String            @id
  name      String
  ownerId   String
  plan      String            @default("starter")
  logoUrl   String?
  timezone  String?           @default("UTC")
  createdAt DateTime          @default(now())
  members   WorkspaceMember[]
  // Stage E: outbound CRM webhook config. Kept off the general Workspace read path in
  // workspaceService.ts (see crmWebhookService.ts) so the secret never rides along with
  // normal workspace-profile reads, the same way OAuth tokens stay out of Integration's.
  crmWebhookUrl    String?
  crmWebhookSecret String?

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  role        String    @default("member")
  invitedAt   DateTime
  joinedAt    DateTime?

  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model Business {
  id          String   @id
  workspaceId String?
  domain      String?
  data        Json
  createdAt   DateTime @default(now())

  crawlJobs CrawlJob[]

  @@index([workspaceId])
  @@unique([workspaceId, domain])
  @@map("businesses")
}

model Strategy {
  id         String   @id
  businessId String
  data       Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@map("strategies")
}

model Campaign {
  id          String   @id
  businessId  String
  workspaceId String?
  data        Json
  updatedAt   DateTime @default(now())

  @@index([businessId])
  @@index([workspaceId])
  @@map("campaigns")
}

model AdSet {
  id          String   @id
  campaignId  String
  workspaceId String?
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([campaignId])
  @@index([workspaceId])
  @@map("ad_sets")
}

model Ad {
  id          String   @id
  adSetId     String
  workspaceId String?
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([adSetId])
  @@index([workspaceId])
  @@map("ads")
}

model Metric {
  id         String @id
  campaignId String
  data       Json
  date       String

  @@index([campaignId])
  @@map("metrics")
}

model Invoice {
  id         String   @id
  businessId String
  data       Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@map("invoices")
}

model Creative {
  id         String   @id
  businessId String?
  workspaceId String?
  data       Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([workspaceId])
  @@map("creatives")
}

model Asset {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("assets")
}

model Draft {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("drafts")
}

model Insight {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("insights")
}

model Integration {
  id          String   @id
  workspaceId String
  platform    String
  data        Json
  updatedAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([workspaceId, platform])
  @@map("integrations")
}

model Notification {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("notifications")
}

model SavedAudience {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("saved_audiences")
}

model GenerationJob {
  id          String   @id
  workspaceId String
  businessId  String
  type        String
  status      String   @default("queued")
  input       Json
  result      Json?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([businessId])
  @@map("generation_jobs")
}

// Lead-gen forms synced from Meta (leadgen_forms) or Google (LEAD_FORM assets).
// `data` carries the raw, dynamic-per-form shape (questions/fields/CTA) since
// that varies form-to-form; only what the CRM tab needs to list/link is a column.
model LeadForm {
  id          String   @id
  workspaceId String
  platform    String
  externalId  String
  campaignId  String?
  name        String
  status      String   @default("active")
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  leads       Lead[]

  @@unique([workspaceId, platform, externalId])
  @@index([workspaceId])
  @@index([workspaceId, platform])
  @@map("lead_forms")
}

// Individual lead submissions. email/phone/fullName/submittedAt are pulled out
// of the raw field_data so the CRM tab can paginate/sort/search server-side;
// `data` keeps the full lossless field_data for display (custom questions vary
// per form). Unique on (workspaceId, platform, externalId) so both the Meta
// webhook (which redelivers) and the backfill/poll jobs can safely upsert.
model Lead {
  id          String    @id
  workspaceId String
  platform    String
  externalId  String
  leadFormId  String?
  leadForm    LeadForm? @relation(fields: [leadFormId], references: [id])
  campaignId  String?
  adId        String?
  fullName    String?
  email       String?
  phone       String?
  companyName String?
  status      String    @default("new")
  submittedAt DateTime
  data        Json
  createdAt   DateTime  @default(now())
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])

  @@unique([workspaceId, platform, externalId])
  @@index([workspaceId, submittedAt])
  @@index([workspaceId, platform])
  @@index([leadFormId])
  @@index([campaignId])
  @@index([email])
  @@index([contactId])
  @@map("leads")
}

// The Stage-C "Normalizer" output: one CRM-facing identity per (workspaceId, email-or-phone),
// merged across platforms/forms from the raw Lead rows above. leadCount/firstSeenAt/lastSeenAt
// are maintained by contactService.upsertContactForLead as new leads roll in.
model Contact {
  id          String   @id
  workspaceId String
  email       String?
  phone       String?
  fullName    String?
  companyName String?
  leadCount   Int      @default(1)
  firstSeenAt DateTime
  lastSeenAt  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  leads       Lead[]

  @@index([workspaceId])
  @@index([workspaceId, email])
  @@index([workspaceId, phone])
  @@map("contacts")
}

// Deep web-search-backed research on a promotional URL (product positioning, audience,
// competitors/budget, market/location, audience personas) — deliberately its own model
// rather than reusing GenerationJob, since this is an unrelated feature area with its
// own cost-tracking needs (searchCount, cacheHit). `blocks` accumulates one entry per
// research block as the worker completes it, so polling clients see the transcript grow.
model ResearchSession {
  id          String   @id
  workspaceId String
  businessId  String?
  url         String
  status      String   @default("queued") // queued | running | done | failed
  currentStep String?
  blocks      Json     @default("[]")
  personas    Json?
  campaignSuggestions Json?
  result      Json?
  error       String?
  searchCount Int      @default(0)
  cacheHit    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([url])
  @@map("research_sessions")
}

model SupportTicket {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("support_tickets")
}

// One row per workspace — id is the workspaceId itself, upserted rather than created.
model NotificationPreference {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("notification_preferences")
}

// One row per workspace — id is the workspaceId itself, upserted rather than created.
model RbacRoleMatrix {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("rbac_role_matrices")
}

model DeveloperWebhook {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("developer_webhooks")
}

// One active key per workspace — id is the workspaceId itself, regenerating replaces the row.
model DeveloperApiKey {
  id        String   @id
  key       String
  createdAt DateTime @default(now())

  @@map("developer_api_keys")
}

// data is masked display info only (brand, last4, expiry) — a card number/CVC must never
// land here, mock billing or not; see billingService.ts for what's rejected before storage.
model PaymentMethod {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("payment_methods")
}

// ═══════════════════════════════════════════════════════════════════════
// Research Orchestrator (Campaign -> Research Orchestrator -> Providers ->
// Knowledge Aggregator -> AI Agents -> Campaign). Deliberately separate from
// ResearchSession above rather than a rewrite of it: ResearchSession is the
// existing sequential scraper->OpenAI deep-research pipeline and keeps working
// unchanged for callers still on it; ResearchJob is the new parallel
// multi-provider pipeline, additive to the schema. `context` holds the final
// strongly-typed ResearchContext (see apps/api/src/research/types) once
// aggregation completes; ProviderExecution/ResearchEvidence give per-provider
// observability that ResearchSession's flat `blocks` array never needed
// (single sequential worker, one row was enough).
// ═══════════════════════════════════════════════════════════════════════

model ResearchJob {
  id           String   @id
  workspaceId  String
  businessId   String?
  url          String
  status       String   @default("pending") // pending | running | aggregating | completed | failed
  context      Json?
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  executions ProviderExecution[]
  snapshots  ResearchSnapshot[]
  evidence   ResearchEvidence[]

  @@index([workspaceId])
  @@index([businessId])
  @@index([url])
  @@map("research_jobs")
}

// One row per provider attempt (a retried provider gets multiple rows, one per
// attempt) — kept even after the job completes as an audit trail of what each
// of the 9 providers returned, how long it took, and whether it needed a retry.
model ProviderExecution {
  id            String    @id
  researchJobId String
  researchJob   ResearchJob @relation(fields: [researchJobId], references: [id])
  provider      String
  priority      Int
  status        String    // success | partial | failed
  attempt       Int       @default(1)
  data          Json?
  citations     Json      @default("[]")
  // 0-1, computeConfidence() in research/providers/support.ts — see that function's doc
  // comment for the exact formula. Persisted (not just returned in the live response) so
  // low-confidence providers can be queried/audited after the fact, e.g. "which providers
  // fell back to AI-estimate data most often this month".
  confidence    Float?
  error         String?
  startedAt     DateTime
  completedAt   DateTime?
  durationMs    Int?
  createdAt     DateTime  @default(now())

  @@index([researchJobId])
  @@index([researchJobId, provider])
  @@map("provider_executions")
}

// Immutable point-in-time copy of the aggregated ResearchContext, written once
// per successful aggregation pass. A job normally has exactly one (aggregation
// runs once), but the model allows more so a future re-aggregation/re-run of
// a subset of providers doesn't have to overwrite history.
model ResearchSnapshot {
  id            String   @id
  researchJobId String
  researchJob   ResearchJob @relation(fields: [researchJobId], references: [id])
  version       Int      @default(1)
  context       Json
  createdAt     DateTime @default(now())

  @@index([researchJobId])
  @@map("research_snapshots")
}

// Flattened citation/source trail across all providers for this job — lets the
// UI show "N sources" and link out to them without walking every
// ProviderExecution.citations blob.
model ResearchEvidence {
  id            String   @id
  researchJobId String
  researchJob   ResearchJob @relation(fields: [researchJobId], references: [id])
  provider      String
  url           String
  title         String?
  snippet       String?
  createdAt     DateTime @default(now())

  @@index([researchJobId])
  @@index([researchJobId, provider])
  @@map("research_evidence")
}

// Dead-letter store for permanently-failed BullMQ jobs (every attempt exhausted) — a
// queryable record of what failed and why, distinct from BullMQ's own internal "failed"
// set (Redis-only, not visible through this app's own API/DB). Written by each worker's
// `.on("failed", ...)` handler via infra/deadLetterQueue.ts once isFinalFailure(job) is
// true, i.e. this is the LAST attempt failing, not every intermediate retry.
model DeadLetterEntry {
  id           String   @id
  queue        String
  jobName      String
  jobData      Json
  error        String
  attemptsMade Int
  failedAt     DateTime @default(now())

  @@index([queue])
  @@map("dead_letter_entries")
}

// Research Memory (RAG store for Competitor Intelligence and future consumers) — one
// row per embedded chunk (e.g. one competitor entry, or a whole research summary),
// scoped by workspace/kind so retrieval can be filtered before ranking. `embedding` is
// a plain float array rather than a pgvector `vector(N)` column: this Postgres instance
// doesn't have the pgvector extension installed (native Windows Postgres install, no
// admin-level install path available in this environment — see ResearchMemoryStore.ts
// for the full note). Every read goes through application-side cosine similarity
// (fine at this table's expected size); swapping to real pgvector later only requires
// changing this column's type and ResearchMemoryStore's query implementation — every
// caller (CompetitorProvider today) keeps working unchanged since it only depends on
// ResearchMemoryStore's exported function signatures, not the storage mechanism.
model ResearchMemoryEntry {
  id          String   @id
  workspaceId String
  businessId  String?
  kind        String   // "competitor" today; extensible (e.g. "company", "market")
  sourceUrl   String
  content     String   // the raw text that was embedded — kept for inspection/debugging
  metadata    Json     // structured payload (e.g. a CompetitorEntry or an industry tag)
  embedding   Float[]
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([kind])
  @@map("research_memory_entries")
}

// Tracks one full run of the agent-pipeline (Research Orchestrator -> Knowledge
// Aggregator -> AI Agent Coordinator -> Campaign Builder) end to end — created by
// POST /campaigns/generate, driven by workers/campaignGenerationWorker.ts. Distinct
// from ResearchJob (which only tracks the research phase) since a single generation
// run spans research, all 10 agents, and campaign persistence; `researchJobId` links
// back to the ResearchJob this run's research phase produced for full drill-down via
// GET /research/:id, and `strategyId`/`campaignId` link forward once the pipeline
// completes. No FK relations (same schemaless-blob convention as Campaign/Strategy
// above) since those ids don't exist yet while this row is still mid-pipeline.
model CampaignGenerationJob {
  id               String    @id
  workspaceId      String
  businessId       String
  url              String
  name             String?
  dailyBudgetCents Int?
  status           String    @default("pending") // pending | researching | aggregating | running_agents | building_campaign | completed | failed
  researchJobId    String?
  strategyId       String?
  campaignId       String?
  agentResults     Json?     // Record<string, AgentResult<unknown>>, populated once running_agents completes
  decisionContext  Json?     // DecisionContext (research/decision/types.ts) — populated as soon as the research phase completes, well before agentResults/campaignId
  error            String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([workspaceId])
  @@index([businessId])
  @@map("campaign_generation_jobs")
}

// AI Evaluation harness (see src/eval/) — one row per golden-dataset run against either
// the research providers or the AI agents layer. Deliberately one row per RUN, not one
// row per case: `cases` holds the full per-case breakdown as Json, mirroring how
// ResearchSnapshot stores its whole context as one Json blob rather than a child table —
// a run's pass rate/avg score/regression-vs-baseline is what gets queried and charted,
// individual case detail is drill-down data, not something joined across runs.
model AiEvaluationRun {
  id           String   @id
  suite        String   // e.g. "research-providers", "ai-agents"
  target       String?  // the specific provider/agent name this run covered, or null for "all"
  totalCases   Int
  passedCases  Int
  avgScore     Float    // 0-1, mean of all cases' scores
  avgConfidence Float?  // mean confidence the target(s) reported across all cases, if applicable
  cases        Json     // per-case breakdown: input, expected, actual, score, pass/fail, notes
  startedAt    DateTime
  completedAt  DateTime
  createdAt    DateTime @default(now())

  @@index([suite])
  @@index([suite, target])
  @@map("ai_evaluation_runs")
}

model AutomationRule {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("automation_rules")
}

// One row per workspace — id is the workspaceId itself, upserted rather than created.
model OptimizationGoal {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("optimization_goals")
}

// Campaign Intelligence & Learning System (src/campaign-intelligence/) — closes the loop
// from Decision Engine recommendation -> campaign generation -> real performance ->
// Research Memory. None of these 3 models touch/replace the existing Metric/analyticsStore
// time-series (that stays the raw per-day, per-variant source of truth this layer reads
// from via performancePipeline.ts's normalizePerformance, unmodified) — these are the new,
// higher-level rollups this system adds on top: one point-in-time campaign-level snapshot,
// one row per Decision-Engine recommendation tracking what happened to it, and one row per
// detected recurring winning combination.

// `industry`/`platform` are denormalized onto the fact row (not just buried in `metadata`)
// specifically so the Benchmark Engine's "average CTR by industry" / "average CPC by
// platform" aggregations can group by an indexed column instead of unpacking JSON per row.
model CampaignPerformanceSnapshot {
  id           String   @id
  campaignId   String
  workspaceId  String
  businessId   String?
  industry     String?
  platform     String?
  impressions  Int
  clicks       Int
  conversions  Int
  spendCents   Int
  revenueCents Int
  ctr          Float
  cpcCents     Float?
  cpaCents     Float?
  roas         Float?
  frequency    Float?
  metadata     Json     // variant-level breakdown, source strategy id, etc — extensible without a migration
  capturedAt   DateTime @default(now())

  @@index([campaignId])
  @@index([workspaceId])
  @@index([industry])
  @@index([platform])
  @@map("campaign_performance_snapshots")
}

// One row per Decision Engine recommendation a human/system actually acted on (or didn't).
// `recommendationId` is the Decision Engine's per-run Recommendation.id (positional, e.g.
// "rec-1" — NOT stable across runs), so identity for re-linking a later outcome to the same
// underlying suggestion is (workspaceId, category, title) — the same dedup key convention
// decision-engine.ts already uses when it writes to Research Memory.
model RecommendationFeedback {
  id                 String   @id
  workspaceId        String
  businessId         String?
  recommendationId   String
  category           String
  title              String
  status             String   // "accepted" | "ignored" | "implemented"
  campaignId         String?
  outcomeSummary     String?
  effectivenessScore Float?   // 0-1, set once a linked campaign's performance snapshot lands
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([workspaceId])
  @@index([campaignId])
  @@index([workspaceId, category, title])
  @@map("recommendation_feedback")
}

// A detected recurring winning combination (audience + creative + offer + platform ->
// high ROAS) — success-patterns.ts upserts these as more campaigns close the loop, so
// `occurrences`/`avgRoas`/`confidence` strengthen over time rather than being recomputed
// from scratch on every read.
model SuccessPattern {
  id          String   @id
  workspaceId String
  audience    String
  creative    String
  offer       String
  platform    String
  occurrences Int      @default(1)
  avgRoas     Float?
  avgCtr      Float?
  confidence  Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@map("success_patterns")
}

// One row per website-crawl attempt (initial onboarding crawl or a later re-crawl), so
// crawl history/comparison across time is possible instead of each crawl overwriting the
// last. Optionally linked to the ResearchJob that triggered it when run via WebsiteProvider
// inside the 9-provider research pipeline — CrawlJob also stands alone for a future
// standalone re-crawl trigger that isn't part of that pipeline.
model CrawlJob {
  id              String    @id
  businessId      String
  business        Business  @relation(fields: [businessId], references: [id])
  workspaceId     String
  researchJobId   String?
  url             String
  status          String    @default("pending") // pending | crawling | completed | failed
  pagesDiscovered Int       @default(0)
  pagesCrawled    Int       @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  error           String?
  createdAt       DateTime  @default(now())

  pages CrawlPage[]
  facts CrawlFact[]

  @@index([businessId])
  @@index([workspaceId])
  @@map("crawl_jobs")
}

// One row per page fetched during a CrawlJob — replaces flattening every page's text into
// one blob. rawHtmlKey/screenshotKey point at objectStorage (apps/api/src/infra/objectStorage.ts);
// only structured/queryable fields plus those references live in Postgres.
model CrawlPage {
  id             String    @id
  crawlJobId     String
  crawlJob       CrawlJob  @relation(fields: [crawlJobId], references: [id])
  url            String
  pageType       String?
  title          String?
  relevanceScore Float?
  contentHash    String?
  cleanedText    String?
  rawHtmlKey     String?
  screenshotKey  String?
  status         String    @default("fetched") // fetched | failed
  error          String?
  fetchedAt      DateTime  @default(now())

  facts CrawlFact[]

  @@index([crawlJobId])
  @@map("crawl_pages")
}

// A single extracted fact with provenance — the source page it came from plus a confidence
// score, so a downstream strategy claim like "starting price is X" can be traced back and
// verified rather than trusting an unattributed LLM summary.
model CrawlFact {
  id          String     @id
  crawlJobId  String
  crawlJob    CrawlJob   @relation(fields: [crawlJobId], references: [id])
  crawlPageId String?
  crawlPage   CrawlPage? @relation(fields: [crawlPageId], references: [id])
  field       String
  value       String
  confidence  Float
  createdAt   DateTime   @default(now())

  @@index([crawlJobId])
  @@index([crawlPageId])
  @@map("crawl_facts")
}

// ── AI Advertising Intelligence Platform: persistent Intelligence Layer ──
// Everything below is additive on top of the existing Research -> Agents -> Strategy ->
// Campaign pipeline (none of the models above are touched). See
// research/company-knowledge/, research/competitor-intelligence/, research/ad-intelligence/,
// research/creative-intelligence/, research/campaign-recommendation/.

// The Company Knowledge Builder's persisted output — one current row per business, built
// from ResearchContext + CrawlFact rows (not a fresh research call). Upserted on each
// successful research run rather than versioned: ResearchJob already keeps the underlying
// research history this is assembled from, so a separate history table would just duplicate it.
model CompanyProfile {
  id                  String   @id
  businessId          String   @unique
  workspaceId         String
  sourceResearchJobId String?
  data                Json     // overview, products, services, features, pricing, industries,
                                // targetAudience, icp, personas, technology, positioning,
                                // messaging, socialProof, faqs
  generatedAt         DateTime @default(now())

  @@index([workspaceId])
  @@map("company_profiles")
}

// A relational competitor entity — research/competitor-intelligence/CompetitorIntelligenceEngine.ts
// already discovers and enriches these; this table makes a competitor a queryable, rankable,
// refreshable thing instead of only a Research Memory embedding blob (kind: "competitor-profile").
model Competitor {
  id                  String    @id
  businessId          String
  workspaceId         String
  name                String
  domain              String?
  discoverySources    Json      // mirrors DiscoveredCompetitor.mentionedBy
  status              String    @default("active") // active | archived
  refreshIntervalDays Int       @default(30)
  lastEnrichedAt      DateTime?
  createdAt           DateTime  @default(now())

  profiles CompetitorProfile[]
  ads      CompetitorAd[]

  @@index([businessId])
  @@index([workspaceId])
  @@unique([businessId, name])
  @@map("competitors")
}

// One row per enrichment run — history preserved (never overwritten) so drift/trend across
// runs is visible; "current" profile for a competitor = latest row by generatedAt. Mirrors
// exactly what research/competitor-intelligence/enrichment.ts's enrichCompetitor() computes.
model CompetitorProfile {
  id                          String     @id
  competitorId                String
  competitor                  Competitor @relation(fields: [competitorId], references: [id])
  positioning                 String
  pricing                     String
  targetAudience              String
  valueProposition            String
  strengths                   Json
  weaknesses                  Json
  technologyStack             Json
  estimatedMarketingStrategy  String
  marketShare                 String
  estimatedAdBudget           String
  differentiation             String
  confidence                  Float
  mentionedBySourceCount      Int
  citations                   Json
  generatedAt                 DateTime   @default(now())

  @@index([competitorId])
  @@index([competitorId, generatedAt])
  @@map("competitor_profiles")
}

// One row per discovered ad, upserted on every refresh pass (competitor-ad-refresh queue) so
// firstSeenAt/lastSeenAt/isActive reflect real observation history, not a single scrape.
model CompetitorAd {
  id                 String    @id
  competitorId       String
  competitor         Competitor @relation(fields: [competitorId], references: [id])
  platform           String    // meta | google | linkedin | youtube | other
  externalAdId       String
  headline           String?
  description        String?
  cta                String?
  imageUrl           String?
  videoUrl           String?
  landingPageUrl     String?
  estimatedCountries Json      @default("[]")
  language           String?
  firstSeenAt        DateTime  @default(now())
  lastSeenAt         DateTime  @default(now())
  isActive           Boolean   @default(true)
  rawSourceData      Json
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  creativeAnalysis AdCreativeAnalysis?

  @@index([competitorId])
  @@index([competitorId, isActive])
  @@unique([competitorId, platform, externalAdId])
  @@map("competitor_ads")
}

// Per-ad structured creative breakdown (research/creative-intelligence/AdCreativeAnalyzer.ts)
// — distinct from CreativeIntelligenceEngine's per-COMPETITOR aggregate messaging analysis;
// this is one LLM extraction pass per individual ad's actual headline/body/image/CTA.
model AdCreativeAnalysis {
  id               String       @id
  competitorAdId   String       @unique
  competitorAd     CompetitorAd @relation(fields: [competitorAdId], references: [id])
  hook             String
  painPoint        String
  offer            String
  emotionalTrigger String
  cta              String
  funnelStage      String
  persona          String
  creativeStyle    String
  messagingStyle   String
  confidence       Float
  generatedAt      DateTime     @default(now())

  @@map("ad_creative_analyses")
}

// ── Wallet / Prepaid Balance ──
// One row per workspace (id = workspaceId, upserted) holding the current balance
// and metadata; WalletTransaction is the append-only ledger of every credit/debit.

model Wallet {
  id          String   @id // = workspaceId
  workspaceId String   @unique
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("wallets")
}

model WalletTransaction {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("wallet_transactions")
}

// The 6 ranked, fully-specified campaign packages the Campaign Recommendation Engine
// (research/campaign-recommendation/CampaignRecommendationEngine.ts) assembles from
// already-computed strategies/simulations + real agent creatives + the landing-page
// recommendation — additive alongside (never replacing) the single Campaign the existing
// pipeline still builds via buildCampaignFromStrategy.
model CampaignRecommendation {
  id                        String   @id
  campaignGenerationJobId   String
  rank                      Int      // 1-6
  objective                 String
  platform                  String
  audience                  String
  dailyBudgetCents          Int
  campaignStructure         Json
  adSets                    Json
  creatives                 Json
  headlines                 Json
  primaryText               String
  cta                       String
  landingPageRecommendation String
  confidenceScore           Float
  explanation               String
  generatedAt               DateTime @default(now())

  @@index([campaignGenerationJobId])
  @@unique([campaignGenerationJobId, rank])
  @@map("campaign_recommendations")
}
