// Data model for AdGo, mirroring the shape of the app that was actually built
// (see apps/api/src/db/db.ts for the SQLite predecessor this replaces).
// Most tables keep a `data Json` blob column matching how the app already
// reads/writes these records — this is a driver swap (SQLite -> Postgres),
// not a data-model redesign. workspace_members relates to Workspace (for the
// listWorkspacesForUser join) but NOT to User: inviteMember() can create a
// member row for an email with no User yet (userId = "pending:<email>"), so
// userId is a plain indexed column rather than an enforced FK.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String?
  name         String
  avatar       String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())

  @@map("users")
}

model Workspace {
  id        String            @id
  name      String
  ownerId   String
  plan      String            @default("starter")
  logoUrl   String?
  timezone  String?           @default("UTC")
  createdAt DateTime          @default(now())
  members   WorkspaceMember[]
  // Stage E: outbound CRM webhook config. Kept off the general Workspace read path in
  // workspaceService.ts (see crmWebhookService.ts) so the secret never rides along with
  // normal workspace-profile reads, the same way OAuth tokens stay out of Integration's.
  crmWebhookUrl    String?
  crmWebhookSecret String?

  @@index([ownerId])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  userId      String
  role        String    @default("member")
  invitedAt   DateTime
  joinedAt    DateTime?

  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model Business {
  id          String   @id
  workspaceId String?
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("businesses")
}

model Strategy {
  id         String   @id
  businessId String
  data       Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@map("strategies")
}

model Campaign {
  id          String   @id
  businessId  String
  workspaceId String?
  data        Json
  updatedAt   DateTime @default(now())

  @@index([businessId])
  @@index([workspaceId])
  @@map("campaigns")
}

model AdSet {
  id          String   @id
  campaignId  String
  workspaceId String?
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([campaignId])
  @@index([workspaceId])
  @@map("ad_sets")
}

model Ad {
  id          String   @id
  adSetId     String
  workspaceId String?
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([adSetId])
  @@index([workspaceId])
  @@map("ads")
}

model Metric {
  id         String @id
  campaignId String
  data       Json
  date       String

  @@index([campaignId])
  @@map("metrics")
}

model Invoice {
  id         String   @id
  businessId String
  data       Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@map("invoices")
}

model Creative {
  id         String   @id
  businessId String?
  workspaceId String?
  data       Json
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([workspaceId])
  @@map("creatives")
}

model Asset {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("assets")
}

model Draft {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("drafts")
}

model Insight {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("insights")
}

model Integration {
  id          String   @id
  workspaceId String
  platform    String
  data        Json
  updatedAt   DateTime @default(now())

  @@index([workspaceId])
  @@index([workspaceId, platform])
  @@map("integrations")
}

model Notification {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("notifications")
}

model SavedAudience {
  id          String   @id
  workspaceId String
  data        Json
  createdAt   DateTime @default(now())

  @@index([workspaceId])
  @@map("saved_audiences")
}

model GenerationJob {
  id          String   @id
  workspaceId String
  businessId  String
  type        String
  status      String   @default("queued")
  input       Json
  result      Json?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([businessId])
  @@map("generation_jobs")
}

// Lead-gen forms synced from Meta (leadgen_forms) or Google (LEAD_FORM assets).
// `data` carries the raw, dynamic-per-form shape (questions/fields/CTA) since
// that varies form-to-form; only what the CRM tab needs to list/link is a column.
model LeadForm {
  id          String   @id
  workspaceId String
  platform    String
  externalId  String
  campaignId  String?
  name        String
  status      String   @default("active")
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  leads       Lead[]

  @@unique([workspaceId, platform, externalId])
  @@index([workspaceId])
  @@index([workspaceId, platform])
  @@map("lead_forms")
}

// Individual lead submissions. email/phone/fullName/submittedAt are pulled out
// of the raw field_data so the CRM tab can paginate/sort/search server-side;
// `data` keeps the full lossless field_data for display (custom questions vary
// per form). Unique on (workspaceId, platform, externalId) so both the Meta
// webhook (which redelivers) and the backfill/poll jobs can safely upsert.
model Lead {
  id          String    @id
  workspaceId String
  platform    String
  externalId  String
  leadFormId  String?
  leadForm    LeadForm? @relation(fields: [leadFormId], references: [id])
  campaignId  String?
  adId        String?
  fullName    String?
  email       String?
  phone       String?
  companyName String?
  status      String    @default("new")
  submittedAt DateTime
  data        Json
  createdAt   DateTime  @default(now())
  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id])

  @@unique([workspaceId, platform, externalId])
  @@index([workspaceId, submittedAt])
  @@index([workspaceId, platform])
  @@index([leadFormId])
  @@index([campaignId])
  @@index([email])
  @@index([contactId])
  @@map("leads")
}

// The Stage-C "Normalizer" output: one CRM-facing identity per (workspaceId, email-or-phone),
// merged across platforms/forms from the raw Lead rows above. leadCount/firstSeenAt/lastSeenAt
// are maintained by contactService.upsertContactForLead as new leads roll in.
model Contact {
  id          String   @id
  workspaceId String
  email       String?
  phone       String?
  fullName    String?
  companyName String?
  leadCount   Int      @default(1)
  firstSeenAt DateTime
  lastSeenAt  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())
  leads       Lead[]

  @@index([workspaceId])
  @@index([workspaceId, email])
  @@index([workspaceId, phone])
  @@map("contacts")
}

// Deep web-search-backed research on a promotional URL (product positioning, audience,
// competitors/budget, market/location, audience personas) — deliberately its own model
// rather than reusing GenerationJob, since this is an unrelated feature area with its
// own cost-tracking needs (searchCount, cacheHit). `blocks` accumulates one entry per
// research block as the worker completes it, so polling clients see the transcript grow.
model ResearchSession {
  id          String   @id
  workspaceId String
  businessId  String?
  url         String
  status      String   @default("queued") // queued | running | done | failed
  currentStep String?
  blocks      Json     @default("[]")
  personas    Json?
  campaignSuggestions Json?
  result      Json?
  error       String?
  searchCount Int      @default(0)
  cacheHit    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([url])
  @@map("research_sessions")
}
