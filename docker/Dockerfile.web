# syntax=docker/dockerfile:1

FROM node:20-bookworm-slim AS deps
WORKDIR /repo
COPY package.json package-lock.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/web/package.json apps/web/package.json
COPY apps/auth-service/package.json apps/auth-service/package.json
COPY apps/campaign-service/package.json apps/campaign-service/package.json
COPY apps/scraper-service/package.json apps/scraper-service/package.json
RUN npm ci --ignore-scripts

FROM deps AS build
COPY . .
RUN npm run build --workspace apps/web

# The frontend never had a production serving story (vite build produced a static bundle
# with nothing to serve it) — nginx is the standard, battle-tested choice for a SPA bundle,
# and doubles as the reverse proxy for /api and /objects so apps/web's existing relative-path
# API calls need no changes between dev (vite proxy) and prod (nginx proxy).
FROM nginx:1.27-alpine AS runtime
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /repo/apps/web/dist /usr/share/nginx/html
